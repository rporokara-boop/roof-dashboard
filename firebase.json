{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "Roof_Myyntijohtajan_Dashboard.html",
      "Projektihistoria/**",
      "Myyntijohdon palaverit/**",
      "Q1_2026_osapuolille/**",
      "**/*.pdf",
      "**/*.docx",
      "**/*.mp4",
      "**/*.key",
      "**/*.xlsx",
      "**/*.csv",
      "~$*"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/Roof_Valittaja_Dashboard.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ]
      }
    ]
  }
}
